meta {
  name: 03 - 1st StudentContactAssociation - primaryContactStatus was Updated
  type: http
  seq: 3
}

get {
  url: {{resourceBaseUrl}}/ed-fi/studentContactAssociations/{{firstStudentContactAssociationUniqueId}}
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body: isDefined
  res.body: isNotEmpty
  res.body.id: isString
  res.body.id: isNotEmpty
  res.body.contactReference: isDefined
  res.body.contactReference.contactUniqueId: isString
  res.body.contactReference.contactUniqueId: isNotEmpty
  res.body.studentReference: isDefined
  res.body.studentReference.studentUniqueId: isString
  res.body.studentReference.studentUniqueId: isNotEmpty
  res.body.relationDescriptor: isString
  res.body.relationDescriptor: isNotEmpty
  res.body.primaryContactStatus: isBoolean
  res.body.emergencyContactStatus: isBoolean
}

script:pre-request {
  const { validateDependency } = require('./utils');

  validateDependency(bru, 'firstStudentContactAssociationUniqueId', '01 - 1st StudentContactAssociation is valid', { actionHint: 'Ensure you ran the first certification scenario successfully before continuing.' });
  validateDependency(bru, 'firstStudentContactAssociationPrimaryContactStatus', '01 - 1st StudentContactAssociation is valid', { actionHint: 'Ensure you ran the first certification scenario successfully before continuing.' });
}

script:post-response {
  const { getVar, expectChanged, throwNotFoundOrSpecificError } = require('./utils');
  const { logSpecStudentContactAssociation, logScenario } = require('./logging');
  const entityName = 'StudentContactAssociation';
  const scenarioName = this.req.name;

  if (res.status === 200 && res.body) {
    const current = res.getBody();
    expectChanged(getVar(bru, 'firstStudentContactAssociationPrimaryContactStatus'), current.primaryContactStatus, 'primaryContactStatus');
    logScenario(entityName, scenarioName, current, logSpecStudentContactAssociation, ['contactUniqueId', 'primaryContactStatus']);
  } else {
    throwNotFoundOrSpecificError(entityName);
  }
}

settings {
  encodeUrl: true
}
