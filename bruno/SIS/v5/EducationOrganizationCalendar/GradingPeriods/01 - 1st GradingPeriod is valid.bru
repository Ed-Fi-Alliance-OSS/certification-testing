meta {
  name: 01 - 1st GradingPeriod is valid
  type: http
  seq: 1
}

get {
  url: {{resourceBaseUrl}}/ed-fi/gradingPeriods?schoolId=[ENTER FIRST SCHOOL ID]&schoolYear=[ENTER CURRENT SCHOOL YEAR]&gradingPeriodName=[ENTER GRADING PERIOD NAME]&gradingPeriodDescriptor={{firstGradingDescriptorEncoded}}&gradingPeriodDescriptor_KEEP_IT_AT_THE_END=[ENTER GRADING PERIOD DESCRIPTOR]
  body: none
  auth: inherit
}

params:query {
  schoolId: [ENTER FIRST SCHOOL ID]
  schoolYear: [ENTER CURRENT SCHOOL YEAR]
  gradingPeriodName: [ENTER GRADING PERIOD NAME]
  gradingPeriodDescriptor: {{firstGradingDescriptorEncoded}}
  gradingPeriodDescriptor_KEEP_IT_AT_THE_END: [ENTER GRADING PERIOD DESCRIPTOR]
}

assert {
  res.status: eq 200
  res.body: isArray
  res.body: isNotEmpty
  res.body[0].id: isString
  res.body[0].id: isNotEmpty
  res.body[0].gradingPeriodDescriptor: isString
  res.body[0].gradingPeriodDescriptor: isNotEmpty
  res.body[0].periodSequence: isNumber
  res.body[0].periodSequence: neq 0
  res.body[0].schoolReference: isDefined
  res.body[0].schoolReference.schoolId: isNumber
  res.body[0].schoolReference.schoolId: neq 0
  res.body[0].schoolYearTypeReference: isDefined
  res.body[0].schoolYearTypeReference.schoolYear: isNumber
  res.body[0].schoolYearTypeReference.schoolYear: neq 0
  res.body[0].beginDate: isString
  res.body[0].beginDate: isNotEmpty
  res.body[0].endDate: isString
  res.body[0].endDate: isNotEmpty
  res.body[0].totalInstructionalDays: isNumber
  res.body[0].totalInstructionalDays: neq 0
  res.body[0].gradingPeriodName: isString
  res.body[0].gradingPeriodName: isNotEmpty
}

script:pre-request {
  const { encodeDescriptorParameter } = require('./utils');
  
  const gradingPeriodDescriptorEncoded = encodeDescriptorParameter(req.url, 'gradingPeriodDescriptor_KEEP_IT_AT_THE_END');
  
  bru.setVar('firstGradingDescriptorEncoded', gradingPeriodDescriptorEncoded);
}

script:post-response {
  	const { pickSingle, setVars, wipeVars } = require('./utils');
  	const { logSpecGradingPeriod, logScenario } = require('./logging');
  	const entityName = 'GradingPeriod';
  	const scenarioName = this.req.name;
  	const gp = pickSingle(res.getBody());
  
  if (!gp) {
  		wipeVars(bru, [
  			'firstGradingPeriodUniqueId',
  			'firstGradingPeriodEndDate',
  			'firstGradingPeriodTotalInstructionalDays'
  		], entityName, true);
  	}
  
  	setVars(bru, {
  		firstGradingPeriodUniqueId: gp.id,
  		firstGradingPeriodEndDate: gp.endDate,
  		firstGradingPeriodTotalInstructionalDays: gp.totalInstructionalDays
  	}, entityName);
  	logScenario(entityName, scenarioName, gp, logSpecGradingPeriod);
}

settings {
  encodeUrl: false
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
