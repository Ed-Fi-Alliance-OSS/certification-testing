meta {
  name: 04 - 2nd StudTitleIPartAProgAssocs - titleIPartAParticipantDescriptor was Updated
  type: http
  seq: 4
}

get {
  url: {{resourceBaseUrl}}/ed-fi/studentTitleIPartAProgramAssociations/{{secondStudTitleIPartAProgAssocsUniqueId}}
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body: isDefined
  res.body.id: isString
  res.body.id: isNotEmpty
  res.body.beginDate: isString
  res.body.beginDate: isNotEmpty
  res.body.educationOrganizationReference: isDefined
  res.body.educationOrganizationReference.educationOrganizationId: isNumber
  res.body.educationOrganizationReference.educationOrganizationId: neq 0
  res.body.programReference: isDefined
  res.body.programReference.educationOrganizationId: isNumber
  res.body.programReference.educationOrganizationId: neq 0
  res.body.programReference.programName: isString
  res.body.programReference.programName: isNotEmpty
  res.body.programReference.programTypeDescriptor: isString
  res.body.programReference.programTypeDescriptor: isNotEmpty
  res.body.studentReference: isDefined
  res.body.studentReference.studentUniqueId: isString
  res.body.studentReference.studentUniqueId: isNotEmpty
  res.body.titleIPartAParticipantDescriptor: isString
  res.body.titleIPartAParticipantDescriptor: isNotEmpty
}

script:pre-request {
  const { validateDependency } = require('./utils');

  validateDependency(bru, 'secondStudTitleIPartAProgAssocsUniqueId', '02 - 2nd StudTitleIPartAProgAssocs is valid', {
    actionHint: 'Ensure you ran the second certification scenario successfully before continuing.'
  });
  validateDependency(bru, 'secondStudTitleIPartAProgAssocsTitleIPartAParticipantDescriptor', '02 - 2nd StudTitleIPartAProgAssocs is valid', {
    actionHint: 'Ensure you ran the second certification scenario successfully before continuing.'
  });
}

script:post-response {
  const { getVar, expectChanged, extractDescriptor, throwNotFoundOrSpecificError } = require('./utils');
  const { logSpecStudTitleIPartAProgAssocs, logScenario } = require('./logging');
  const entityName = 'StudTitleIPartAProgAssocs';
  const scenarioName = this.req.name;

  if (res.status !== 200 || !res.body) {
    throwNotFoundOrSpecificError(entityName);
  }

  const current = res.getBody();
  const previousDescriptor = getVar(bru, 'secondStudTitleIPartAProgAssocsTitleIPartAParticipantDescriptor');
  const currentDescriptor = extractDescriptor(current.titleIPartAParticipantDescriptor);

  expectChanged(previousDescriptor, currentDescriptor, 'titleIPartAParticipantDescriptor');

  logScenario(entityName, scenarioName, current, logSpecStudTitleIPartAProgAssocs, [
    'educationOrganizationId',
    'programEducationOrganizationId',
    'programName',
    'programTypeDescriptor',
    'beginDate',
    'studentUniqueId',
    'titleIPartAParticipantDescriptor'
  ]);
}

settings {
  encodeUrl: true
  timeout: 0
}
