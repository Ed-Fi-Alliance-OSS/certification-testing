meta {
  name: 02 - CREATE ClassPeriod 1
  type: http
  seq: 2
}

post {
  url: {{resourceBaseUrl}}/ed-fi/classPeriods
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "classPeriodName": "[CLASS_PERIOD_NAME_1]",
    "schoolReference": {
      "schoolId": "[ENTER_SCHOOL_ID]"
    },
    "meetingTimes": [{
      "startTime": "15:00:00",
      "endTime": "16:00:00"
    }],
    "officialAttendancePeriod": true
  }
}

assert {
  res.status: in [200, 201]
}

script:post-response {
  const locationHeader = res.headers.Location || res.headers.location;

  if (locationHeader) {
    const tempClassPeriodId = locationHeader.split('/').pop();
    bru.setVar('tempClassPeriodId_1', tempClassPeriodId);
    console.log('ClassPeriod "[CLASS_PERIOD_NAME_1]" was created correctly. (uniqueId: ' + tempClassPeriodId + ')');
  } else {
    console.log('There was an error creating ClassPeriod "[CLASS_PERIOD_NAME_1]" response:');
    console.log(res);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
