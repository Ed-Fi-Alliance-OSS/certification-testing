meta {
  name: 06 - DELETE School
  type: http
  seq: 10
}

delete {
  url: {{resourceBaseUrl}}/ed-fi/schools/{{tempSchoolUniqueId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

assert {
  res.status: eq 204
}

script:post-response {
  if (res.status === 204) {
    console.log('School "' + bru.getEnvVar('tempSchoolUniqueId') + '" was deleted correctly.');
  } else {
    console.log('There was an error deleting School "' + bru.getEnvVar('tempSchoolUniqueId') + '" response:');
    console.log(JSON.stringify(res));
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
