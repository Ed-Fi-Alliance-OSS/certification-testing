meta {
  name: 05 - DELETE ClassPeriod 2
  type: http
  seq: 8
}

delete {
  url: {{resourceBaseUrl}}/ed-fi/classPeriods/{{tempClassPeriodId_2}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

assert {
  res.status: eq 204
}

script:post-response {
  if (res.status === 204) {
    console.log('ClassPeriod 2 "' + bru.getEnvVar('tempClassPeriodId_2') + '" was deleted correctly.');
  } else {
    console.log('There was an error deleting ClassPeriod 2 "' + bru.getEnvVar('tempClassPeriodId_2') + '" response:');
    console.log(JSON.stringify(res));
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
