meta {
  name: 05 - DELETE ClassPeriod 3
  type: http
  seq: 9
}

delete {
  url: {{resourceBaseUrl}}/ed-fi/classPeriods/{{tempClassPeriodId_3}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

script:post-response {
  if (res.status === 204) {
    console.log('ClassPeriod 3 "{{tempClassPeriodId_3}}" was deleted correctly.');
  } else {
    console.log('There was an error deleting ClassPeriod 3 "{{tempClassPeriodId_3}}" response:');
    console.log(res);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
