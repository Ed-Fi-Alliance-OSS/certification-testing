meta {
  name: 05 - DELETE ClassPeriod 1
  type: http
  seq: 7
}

delete {
  url: {{resourceBaseUrl}}/ed-fi/classPeriods/{{tempClassPeriodId_1}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

script:post-response {
  if (res.status === 204) {
    console.log('ClassPeriod 1 "{{tempClassPeriodId_1}}" was deleted correctly.');
  } else {
    console.log('There was an error deleting ClassPeriod 1 "{{tempClassPeriodId_1}}" response:');
    console.log(res);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
