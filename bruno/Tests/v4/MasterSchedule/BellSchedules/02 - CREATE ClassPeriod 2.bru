meta {
  name: 02 - CREATE ClassPeriod 2
  type: http
  seq: 3
}

post {
  url: {{resourceBaseUrl}}/ed-fi/classPeriods
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "classPeriodName": "[CLASS_PERIOD_NAME_2]",
    "schoolReference": {
      "schoolId": "[ENTER_SCHOOL_ID]"
    },
    "meetingTimes": [{
      "startTime": "15:00:00",
      "endTime": "16:00:00"
    }],
    "officialAttendancePeriod": true
  }
}

script:post-response {
  const locationHeader = res.headers.Location || res.headers.location;

  if (locationHeader) {
    const tempClassPeriodId = locationHeader.split('/').pop();
    bru.setEnvVar('tempClassPeriodId_2', tempClassPeriodId);
    console.log('ClassPeriod "[CLASS_PERIOD_NAME_2]" was created correctly.');
  } else {
    console.log('There was an error creating ClassPeriod "[CLASS_PERIOD_NAME_2]" response:');
    console.log(res);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
