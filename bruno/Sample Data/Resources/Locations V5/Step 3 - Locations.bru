meta {
  name: Step 3 - Locations
  type: http
  seq: 8
}

put {
  url: {{resourceBaseUrl}}/ed-fi/locations/{{tempFirstLocationUUID}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "id": "{{tempFirstLocationUUID}}",
    "classroomIdentificationCode": "501",
    "schoolReference": {
      "schoolId": 9999999901
    },
    "maximumNumberOfSeats": 20
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
