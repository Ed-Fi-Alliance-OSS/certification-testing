meta {
  name: Aux 3 - Locations
  type: http
  seq: 3
}

put {
  url: {{resourceBaseUrl}}/ed-fi/locations/{{tempLocationUUID}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "id": "{{tempLocationUUID}}",
    "classroomIdentificationCode": "[ENTER CLASSROOM IDENTIFICATION CODE]",
    "schoolReference": {
      "schoolId": [ENTER SCHOOL ID]
    },
    "maximumNumberOfSeats": 22
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
