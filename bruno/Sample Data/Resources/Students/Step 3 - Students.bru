meta {
  name: Step 3 - Students
  type: http
  seq: 8
}

put {
  url: {{resourceBaseUrl}}/ed-fi/students/{{tempFirstStudentUUID}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "id": "{{tempFirstStudentUUID}}",
    "studentUniqueId": "99999901",
    "birthCity": "Grand Bend",
    "birthCountryDescriptor": "uri://ed-fi.org/CountryDescriptor#AG",
    "birthDate": "2009-01-02",
    "firstName": "Austin",
    "middleName": "Samuel",
    "lastSurname": "Jones",
    "generationCodeSuffix": "JR",
    "personalTitlePrefix": "Mr."
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
