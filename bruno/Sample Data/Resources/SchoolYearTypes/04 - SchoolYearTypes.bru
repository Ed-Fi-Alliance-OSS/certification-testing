meta {
  name: 04 - SchoolYearTypes
  type: http
  seq: 4
}

put {
  url: {{resourceBaseUrl}}/ed-fi/SchoolYearTypes/{{tempSchoolYearTypeUniqueId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "id": "{{tempSchoolYearTypeUniqueId}}",
    "schoolYear": 2026,
    "currentSchoolYear": true,
    "schoolYearDescription": "2026-2027"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
