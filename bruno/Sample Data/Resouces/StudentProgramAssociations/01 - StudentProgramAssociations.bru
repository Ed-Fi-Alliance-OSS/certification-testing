meta {
  name: 01 - StudentProgramAssociations
  type: http
  seq: 1
}

get {
  url: {{resourceBaseUrl}}/ed-fi/studentProgramAssociations?studentUniqueId=[ENTER_STUDENT_UNIQUE_ID]&programName=[ENTER_PROGRAM_NAME]&programTypeDescriptor=[ENTER_PROGRAM_TYPE]&educationOrganizationId=[ENTER_EDORG_ID]&beginDate=[ENTER_BEGIN_DATE]
  body: none
  auth: bearer
}

params:query {
  studentUniqueId: [ENTER_STUDENT_UNIQUE_ID]
  programName: [ENTER_PROGRAM_NAME]
  programTypeDescriptor: [ENTER_PROGRAM_TYPE]
  educationOrganizationId: [ENTER_EDORG_ID]
  beginDate: [ENTER_BEGIN_DATE]
}

auth:bearer {
  token: {{edFiCertToken}}
}

script:post-response {
  const { setVar, setVarsMessage, wipeVar, wipeVarsWarning, pickSingle } = require('./utils');
  const item = pickSingle(res.getBody());

  if (item) {
    setVar(bru, 'tempStudentProgramAssocUUID', item.id);
    setVarsMessage('StudentProgramAssociation');
  } else {
    wipeVar(bru, 'tempStudentProgramAssocUUID');
    wipeVarsWarning('StudentProgramAssociation');
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
