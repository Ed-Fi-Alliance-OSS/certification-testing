meta {
  name: 02 - CourseTranscripts
  type: http
  seq: 2
}

post {
  url: {{resourceBaseUrl}}/ed-fi/courseTranscripts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "courseReference": {
      "courseCode": "[ENTER_COURSE_CODE]",
      "educationOrganizationId": [ENTER_EDORG_ID]
    },
    "studentAcademicRecordReference": {
      "studentUniqueId": "[ENTER_STUDENT_UNIQUE_ID]",
      "educationOrganizationId": [ENTER_EDORG_ID],
      "schoolYear": [ENTER_SCHOOL_YEAR],
      "termDescriptor": "[ENTER_TERM_DESCRIPTOR]"
    },
    "courseAttemptResultDescriptor": "uri://ed-fi.org/CourseAttemptResultDescriptor#Pass",
    "attemptedCredits": 3,
    "earnedCredits": 3,
    "finalLetterGradeEarned": "A",
    "finalNumericGradeEarned": 98
  }
}

script:post-response {
  const locationHeader = res.headers.Location || res.headers.location;
  if (locationHeader) {
    const uuid = locationHeader.split('/').pop();
    bru.setVar('tempCourseTranscriptUUID', uuid);
    console.log('CourseTranscript data was created correctly.');
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
