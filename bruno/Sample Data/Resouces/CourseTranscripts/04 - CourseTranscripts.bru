meta {
  name: 04 - CourseTranscripts
  type: http
  seq: 4
}

put {
  url: {{resourceBaseUrl}}/ed-fi/courseTranscripts/{{tempCourseTranscriptUUID}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{edFiCertToken}}
}

body:json {
  {
    "id": "{{tempCourseTranscriptUUID}}",
    "courseReference": {
      "courseCode": "[ENTER_COURSE_CODE]",
      "educationOrganizationId": [ENTER_EDORG_ID]
    },
    "studentAcademicRecordReference": {
      "studentUniqueId": "[ENTER_STUDENT_UNIQUE_ID]",
      "educationOrganizationId": [ENTER_EDORG_ID],
      "schoolYear": [ENTER_SCHOOL_YEAR],
      "termDescriptor": "[ENTER_TERM_DESCRIPTOR]"
    },
    "courseAttemptResultDescriptor": "uri://ed-fi.org/CourseAttemptResultDescriptor#Pass",
    "attemptedCredits": 3,
    "earnedCredits": 3,
    "finalLetterGradeEarned": "A",
    "finalNumericGradeEarned": 100
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
